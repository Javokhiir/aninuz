Options -Indexes
RewriteEngine On

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# /en/ /ru/ /uz/ → en.html / ru.html / uz.html
RewriteRule ^(ru|en|uz)/?$ /$1.html [L]

# /[locale]/[page]/ → /[locale]/[page].html
RewriteRule ^(ru|en|uz)/([^/]+)/?$ /$1/$2.html [L]

# Dynamic product detail: /[locale]/products/[brand]/[product]
RewriteRule ^(ru|en|uz)/products/([^/]+)/([^/]+)/?$ /$1/products/_/_/index.html [L]

# Dynamic company: /[locale]/products/[brand]
RewriteRule ^(ru|en|uz)/products/([^/]+)/?$ /$1/products/_/index.html [L]

# Dynamic events
RewriteRule ^(ru|en|uz)/events/([^/]+)/?$ /$1/events/_/index.html [L]

# Dynamic services
RewriteRule ^(ru|en|uz)/services/([^/]+)/?$ /$1/services/_/index.html [L]

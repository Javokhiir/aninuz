Options -Indexes
RewriteEngine On

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.anin\.uz [NC]
RewriteRule ^(.*)$ https://anin.uz/$1 [R=301,L]

# Redirect root to /en
RewriteRule ^$ /en [R=302,L]

# Serve existing files directly (_next assets, .txt RSC payloads, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# --- Dashboard routes ---
RewriteRule ^dashboard/?$ /dashboard.html [L]
RewriteRule ^dashboard/([^/]+)/?$ /dashboard/$1.html [L]

# --- RSC payload (.txt) rewrites for dynamic routes ---

# /[locale]/products/[brand]/[product].txt → /_/_.txt
RewriteRule ^(ru|en|uz)/products/([^/]+)/([^/]+)\.txt$ /$1/products/_/_.txt [L]

# /[locale]/products/[brand].txt → /_.txt
RewriteRule ^(ru|en|uz)/products/([^/]+)\.txt$ /$1/products/_.txt [L]

# /[locale]/events/[slug].txt → /_.txt
RewriteRule ^(ru|en|uz)/events/([^/]+)\.txt$ /$1/events/_.txt [L]

# /[locale]/services/[slug].txt → /_.txt
RewriteRule ^(ru|en|uz)/services/([^/]+)\.txt$ /$1/services/_.txt [L]

# --- HTML rewrites ---

# /[locale]/ → [locale].html
RewriteRule ^(ru|en|uz)/?$ /$1.html [L]

# /[locale]/[page]/ → /[locale]/[page].html
RewriteRule ^(ru|en|uz)/([^/]+)/?$ /$1/$2.html [L]

# /[locale]/products/[brand]/[product]/ → /[locale]/products/_/_.html
RewriteRule ^(ru|en|uz)/products/([^/]+)/([^/]+)/?$ /$1/products/_/_.html [L]

# /[locale]/products/[brand]/ → /[locale]/products/_.html
RewriteRule ^(ru|en|uz)/products/([^/]+)/?$ /$1/products/_.html [L]

# /[locale]/events/[slug]/ → /[locale]/events/_.html
RewriteRule ^(ru|en|uz)/events/([^/]+)/?$ /$1/events/_.html [L]

# /[locale]/services/[slug]/ → /[locale]/services/_.html
RewriteRule ^(ru|en|uz)/services/([^/]+)/?$ /$1/services/_.html [L]
